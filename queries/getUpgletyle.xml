<query id="getUpgletyle" action="select">
    <tables>
        <table name="domains" alias="domains" type="left join">
			<conditions>
				<condition operation="equal" column="domains.domain_srl" default="modules.domain_srl" filter="number" />
			</conditions>
		</table>
        <table name="modules" alias="modules" />
        <table name="upgletyle" alias="upgletyle" />
        <table name="member" alias="member" type="left join">
			<conditions>
				<condition operation="equal" column="upgletyle.member_srl" default="member.member_srl" />
			</conditions>
		</table>
    </tables>
    <columns>
        <column name="domains.domain" alias="domain" />
        <column name="domains.settings" alias="domain_settings" />
        <column name="member.nick_name" alias="nick_name" />
        <column name="member.user_name" alias="user_name" />
        <column name="member.user_id" alias="user_id" />
        <column name="member.email_address" alais="email_address" />
        <column name="modules.*" />
        <column name="upgletyle.*" />
    </columns>
    <conditions>
        <condition operation="equal" column="modules.module_srl" var="module_srl" notnull="notnull" filter="number" />
        <condition operation="equal" column="modules.module_srl" default="upgletyle.module_srl" filter="number" pipe="and" />
	</conditions>
</query>
